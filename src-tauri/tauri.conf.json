{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Caffei Native",
  "version": "0.1.0",
  "identifier": "com.blue1st.caffei-native",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Caffei Native",
        "width": 600,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 500,
        "minHeight": 500
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "linux": {
      "deb": {
        "desktopTemplate": null,
        "files": {}
      }
    },
    "macOS": {
      "signingIdentity": null,
      "dmg": {
        "background": null
      }
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
